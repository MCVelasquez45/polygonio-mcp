# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
.uv/
uv.lock

# Node projects
node_modules/
/server/node_modules/
/client/node_modules/
/server/dist/
/client/dist/
/server/.env
/client/.env

# Dev platform runtime artifacts
/dev/logs/
/dev/.runtime/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# mypy
.mypy_cache/
.dmypy.json

# Pyre type checker
.pyre/

# Environment variables
.env
.env.*
.env.railway
!.env.example
!**/.env.example
!**/.env_example
!**/env.example

# Project-specific ignores
.cursor/
.taskmaster/
scripts/
.log
.DS_Store

# Re-include required tooling files that the broad rules above would ignore.
# (server/scripts is needed by the `predev` port guard; .python-version pins
#  the screener's Python runtime — both must be in the repo.)
!server/scripts/
!server/scripts/assert-port-free.js
!python-screener-service/.python-version
