# Copy to .env for local development. Never commit real values.

# Runtime
NODE_ENV=development
PORT=4000
PYTHON_URL=http://localhost:5001
AGENT_API_URL=http://localhost:5001
FASTAPI_URL=http://localhost:5001
SCREENER_URL=http://localhost:8001

# Authentication / RBAC
AUTH_JWT_SECRET=<replace-with-local-jwt-secret>
AUTH_JWT_ISSUER=<optional-issuer>
AUTH_JWT_AUDIENCE=<optional-audience>
AUTH_ALLOW_DEV_TOKENS=false
AUTH_DEV_VIEWER_TOKEN=<dev-viewer-token>
AUTH_DEV_TRADER_TOKEN=<dev-trader-token>
AUTH_DEV_ADMIN_TOKEN=<dev-admin-token>

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/market-copilot
MONGODB_URI=mongodb://127.0.0.1:27017/market-copilot
MONGO_OPTIONAL=true
MONGO_LOCAL_FALLBACK=true
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/market-copilot
MONGO_FORCE_IPV4=true

# Massive / Polygon market data
MASSIVE_API_KEY=<massive-or-polygon-api-key>
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_STOCKS_WS_ENABLED=true
MASSIVE_OPTIONS_WS_ENABLED=true
MASSIVE_WS_EAGER_CONNECT=false
MASSIVE_STOCKS_WS_URL=wss://socket.massive.com/stocks
MASSIVE_OPTIONS_WS_URL=wss://socket.massive.com/options
MASSIVE_CACHE_TTL_MS=10000
MASSIVE_TIMEOUT_MS=10000

# Economic / futures data
FRED_API_KEY=<fred-api-key>
DATABENTO_API_KEY=<databento-api-key>
DATABENTO_BASE_URL=https://hist.databento.com
DATABENTO_DATASET=GLBX.MDP3
DATABENTO_SCHEMA=ohlcv-1d
QUANDL_API_KEY=<quandl-or-nasdaq-data-link-api-key>

# OpenAI / SIFT
OPENAI_API_KEY=<openai-api-key>
OPENAI_MODEL=gpt-4o
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
SIFT_PROVIDER=openai
SIFT_MODEL=gpt-4o
OPTION_ASSISTANT_ID=<optional-assistant-id>

# Alpaca paper trading
APCA_API_KEY_ID=<alpaca-key-id>
APCA_API_SECRET_KEY=<alpaca-secret-key>
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex
ALPACA_OPTION_FEED=opra
# Manual paper trading (user-driven, explicit-confirmation surface). Operational
# kill switch: set to false to fail-closed reject all manual submissions at the
# execution gateway. Automation is unaffected (separate governed path).
MANUAL_TRADING_ENABLED=true

# Trading automation universe (Sprint 2E — WATCHLIST is the source of truth)
# The automation engine trades ONLY the user watchlist symbols that have
# enabled=true AND automationEnabled=true (managed via /api/watchlist, effective
# with no restart). There is no env symbol list in the active path.
#
# Watchlist universe cache TTL (read-through cache; also invalidated on every
# watchlist write). Clamped to [15000, 60000] ms.
AUTOMATION_WATCHLIST_CACHE_TTL_MS=30000
#
# DEPRECATED — AUTOMATION_UNDERLYINGS / AUTOMATION_UNDERLYING are NO LONGER the
# automation universe. They are read only by the inactive legacy EQUITY_MOMENTUM
# path and are not required for normal (OPTIONS_NATIVE_FLOW) operation. Leave
# unset; the watchlist governs the universe.
# AUTOMATION_UNDERLYINGS=
# AUTOMATION_UNDERLYING=

# Trading automation (Phase 2C live paper execution)
AUTOMATION_ENABLED=true
AUTOMATION_BROKER=alpaca-paper           # 'mock' forbidden in production
AUTOMATION_SIGNAL_MODE=OPTIONS_NATIVE_FLOW   # authorized-data default
MASSIVE_SUBSCRIPTION_PROFILE=options-advanced
# Options-native signal windows (completed windows only)
AUTOMATION_OPTIONS_FLOW_WINDOW_MINUTES=5
AUTOMATION_OPTIONS_BASELINE_WINDOW_MINUTES=30
# Market-hours lifecycle cutoffs (minutes before the authoritative close)
AUTOMATION_FINAL_ENTRY_MINUTES_BEFORE_CLOSE=45
AUTOMATION_CANCEL_ENTRY_ORDERS_MINUTES_BEFORE_CLOSE=20
AUTOMATION_FLATTEN_MINUTES_BEFORE_CLOSE=15
# Exit policy (snapshotted per trade at fill time)
AUTOMATION_STOP_LOSS_PCT=0.25
AUTOMATION_PROFIT_TARGET_PCT=0.30
AUTOMATION_TRAILING_ENABLED=false
# Exit lifecycle recovery — a position never remains indefinitely in EXITING.
AUTOMATION_MAX_EXIT_RETRIES=3            # exit orders before escalating to MANUAL_REVIEW
AUTOMATION_EXIT_TIMEOUT_MS=300000        # max time in EXITING before MANUAL_REVIEW
# Risk limits
# NOTE: only 1 is supported — the autonomous lifecycle is validated for exactly
# one concurrent position; any other value fails config validation at startup.
AUTOMATION_MAX_CONCURRENT_POSITIONS=1
AUTOMATION_MAX_TRADES_PER_DAY=2
AUTOMATION_RISK_PER_TRADE_PCT=0.0025
AUTOMATION_MAX_DAILY_LOSS_PCT=0.0075
AUTOMATION_CONSECUTIVE_LOSS_PAUSE=2
# Entry execution
AUTOMATION_ENTRY_LIMIT_POLICY=MID        # MID | ASK | BID
AUTOMATION_ENTRY_MAX_SLIPPAGE_PCT=0.05
AUTOMATION_ENTRY_ORDER_TIMEOUT_SECONDS=60
# Schedulers — one cadence/lease-TTL drives BOTH the evaluation scheduler
# (entries) and the monitoring scheduler (stop-loss / profit-target / cancel /
# flatten / EXITING reconciliation). Each takes an independent single-owner DB
# lease (scopes 'automation-scheduler' and 'automation-monitor').
AUTOMATION_SCHEDULER_ENABLED=true
AUTOMATION_SCHEDULER_INTERVAL_MS=30000
AUTOMATION_SCHEDULER_LEASE_TTL_MS=90000  # must exceed INTERVAL_MS
# AUTOMATION_SCHEDULER_WINDOW_MS defaults to OPTIONS_FLOW_WINDOW_MINUTES × 60000
# Sprint 2 — submit approved intents to Alpaca paper. Default OFF: the scheduler
# evaluates but does not submit until execution is deliberately enabled.
AUTOMATION_SUBMIT_APPROVED_INTENTS=false
# Sprint 3 — broker updates, fills, durable positions
AUTOMATION_ORDER_RECONCILIATION_INTERVAL_MS=15000  # clamped to [5000, 300000]
AUTOMATION_BROKER_STREAM_ENABLED=true

# Optional notifications / automation
GITHUB_PAT=<github-token-if-needed>
CHIP_COMMAND_URL=<chip-command-url>
CHIP_NOTIFY_URL=<chip-notify-url>

# Local artifacts and operational controls
FINANCE_AGENT_REPORTS_DIR=<absolute-private-path-outside-repo>
AGG_WORKER_ENABLED=false
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
AI_DAILY_CALL_LIMIT=200
AI_MAX_CONCURRENT=2
AI_MAX_CONCURRENT_PER_USER=1
