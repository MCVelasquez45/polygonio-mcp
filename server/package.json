{
  "name": "market-gateway",
  "private": true,
  "scripts": {
    "predev": "node scripts/assert-port-free.js",
    "dev": "ts-node-dev --respawn --transpile-only ./src/index.ts",
    "build": "tsc",
    "test:auth": "npm run build && node tests/auth-rbac.smoke.js",
    "test:massive": "npm run build && node --test tests/massive.*.test.mjs",
    "start": "node dist/index.js",
    "seed": "bash ../scripts/seed-mongo.sh",
    "seed:docker": "bash ../scripts/seed-mongo.sh --docker",
    "seed:drop": "bash ../scripts/seed-mongo.sh --drop"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.5",
    "mongodb": "^6.21.0",
    "mongoose": "^9.1.3",
    "socket.io": "^4.7.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
